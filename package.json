{
  "name": "neofetchspy",
  "version": "0.1.1",
  "description": "Manifest V3 browser extension for intercepting and modifying fetch responses with configurable rules",
  "type": "module",
  "scripts": {
    "dev": "node scripts/build.mjs --watch",
    "build": "node scripts/build.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "version:sync": "node scripts/sync-version.mjs",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major",
    "version": "npm run version:sync && git add package.json package-lock.json public/manifest.json"
  },
  "dependencies": {
    "jsonpath-plus": "^10.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
